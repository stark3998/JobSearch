{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend",
      "type": "shell",
      "command": "python -m uvicorn backend.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/webapp"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^INFO:.*Uvicorn running",
          "endsPattern": "^INFO:.*Application startup complete"
        }
      },
      "presentation": {
        "group": "servers",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Frontend",
      "type": "shell",
      "command": "npx vite --port 5173",
      "options": {
        "cwd": "${workspaceFolder}/webapp/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*VITE",
          "endsPattern": "Local:.*http"
        }
      },
      "presentation": {
        "group": "servers",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start Dev Servers",
      "dependsOn": ["Backend", "Frontend"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
